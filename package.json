{
  "name": "sshifu-monorepo",
  "version": "0.0.0-dev",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "go build ./cmd/...",
    "build:all": "npm run build && npm run build:binaries",
    "build:binaries": "node scripts/build-all-binaries.js",
    "publish:all": "npm publish --workspaces --access public"
  }
}
